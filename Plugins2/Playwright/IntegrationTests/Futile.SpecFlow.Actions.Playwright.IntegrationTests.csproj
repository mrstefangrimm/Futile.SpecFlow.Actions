<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="SpecFlow.xUnit" Version="$(SpecflowVersion)" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="$(MicrosoftNETTestSdkVersion)" />
    <PackageReference Include="FluentAssertions" Version="$(FluentAssertionsVersion)" />
    <PackageReference Include="xunit.runner.visualstudio" Version="$(XunitRunnerVisualstudioVersion)" />
  </ItemGroup>

  <ItemGroup>
    <!--See: https://andersmadsen.dev/guides/how-to-disable-test-parallelization-in-xunit -->
    <AssemblyAttribute Include="Xunit.CollectionBehaviorAttribute">
      <_Parameter1>DisableTestParallelization = true</_Parameter1>
      <_Parameter1_IsLiteral>true</_Parameter1_IsLiteral>
    </AssemblyAttribute>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Src\Futile.SpecFlow.Actions.Playwright.csproj" />
    <ProjectReference Include="..\..\MultiTargetGeneration\Src\Futile.SpecFlow.Actions.MultiTargetGeneration.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Update="specflow.actions.*.json">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
    <None Update="specflow.actions.json">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <PropertyGroup>
    <_SpecFlow_GeneratorPlugin Condition=" '$(MSBuildRuntimeType)' == 'Core'">net8.0</_SpecFlow_GeneratorPlugin>
    <_SpecFlow_GeneratorPlugin Condition=" '$(MSBuildRuntimeType)' != 'Core'">net48</_SpecFlow_GeneratorPlugin>
    <_SpecFlow_GeneratorPluginPath>..\..\MultiTargetGeneration\Src\bin\Debug\net48\Futile.SpecFlow.Actions.MultiTargetGeneration.SpecFlowPlugin.dll</_SpecFlow_GeneratorPluginPath>
  </PropertyGroup>

  <ItemGroup>
    <SpecFlowGeneratorPlugins Include="$(_SpecFlow_GeneratorPluginPath)" />
  </ItemGroup>

  <Target Name="BuildDependencies" BeforeTargets="PreBuildEvent;BeforeUpdateFeatureFilesInProject" AfterTargets="PreBuild">
    <MSBuild Projects="..\..\MultiTargetGeneration\Src\Futile.SpecFlow.Actions.MultiTargetGeneration.csproj" Properties="TargetFramework=$(_SpecFlow_GeneratorPlugin)" />
  </Target>

</Project>