<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>Futile.SpecFlow.Actions.Playwright</id>
    <version>$version$</version>
    <authors>$author$</authors>
    <owners>$owner$</owners>
    <description>Fork of SpecFlow.Actions.Playwright</description>
    <license type="file">LICENSE</license>
    <licenseUrl>https://aka.ms/deprecateLicenseUrl</licenseUrl>
    <readme>Readme.md</readme>
    <dependencies>
      <group targetFramework=".NETFramework4.8.1">
        <dependency id="Futile.SpecFlow.Actions.Configuration" version="$version$"/>
        <dependency id="Microsoft.Playwright" version="1.58.0"/>
        <dependency id="SpecFlow" version="3.9.74" />
        <dependency id="System.Text.Json" version="10.0.3" />
      </group>
      <group targetFramework=".NET8.0">
        <dependency id="Futile.SpecFlow.Actions.Configuration" version="$version$"/>
        <dependency id="Microsoft.Playwright" version="1.58.0"/>
        <dependency id="SpecFlow" version="3.9.74"/>
        <dependency id="System.Text.Json" version="10.0.3"/>
      </group>
    </dependencies>
    <frameworkAssemblies>
      <frameworkAssembly assemblyName="System.IO" targetFramework=".NETFramework4.8.1" />
      <frameworkAssembly assemblyName="System.Runtime" targetFramework=".NETFramework4.8.1" />
      <frameworkAssembly assemblyName="System.Security.Cryptography.Encoding" targetFramework=".NETFramework4.8.1" />
      <frameworkAssembly assemblyName="System.Security.Cryptography.Primitives" targetFramework=".NETFramework4.8.1" />
    </frameworkAssemblies>
  </metadata>
  <files>
    <file src="bin\$config$\net481\SpecFlow.Actions.*" target="lib\net481"/>
    <file src="bin\$config$\net8.0\SpecFlow.Actions.*" target="lib\net8.0"/>

    <file src="$SolutionDir$LICENSE" target="LICENSE" />
    <file src="..\README.md" target="" />
  </files>
</package>