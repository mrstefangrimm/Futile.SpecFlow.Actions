<package xmlns="http://schemas.microsoft.com/packaging/2010/07/nuspec.xsd">
  <metadata>
    <id>Futile.SpecFlow.Actions.Configuration</id>
    <version>$version$</version>
    <authors>$author$</authors>
    <owners>$owner$</owners>
    <title>Futile.SpecFlow.Actions.Configuration</title>
    <description>Fork of SpecFlow.Actions.Configuration</description>
    <summary></summary>
    <language>en-US</language>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <tags>specflow</tags>
    <license type="file">LICENSE</license>
    <licenseUrl>https://aka.ms/deprecateLicenseUrl</licenseUrl>
    <readme>Readme.md</readme>
    <dependencies>
      <group targetFramework="net48">
        <dependency id="SpecFlow" version="3.9.74"/>
        <dependency id="Microsoft.Extensions.Configuration.Binder" version="8.0.2" />
        <dependency id="Microsoft.Extensions.Configuration.Json" version="8.0.0" />
      </group>
      <group targetFramework="net8.0">
        <dependency id="SpecFlow" version="3.9.74"/>
        <dependency id="Microsoft.Extensions.Configuration.Binder" version="8.0.2" />
        <dependency id="Microsoft.Extensions.Configuration.Json" version="8.0.0" />
      </group>
    </dependencies>
  </metadata>
  <files>
    <file src="Build\**\*" target="build"/>

    <file src="bin\$config$\net48\SpecFlow.Actions.Configuration.SpecFlowPlugin.*" target="lib\net48"/>
    <file src="bin\$config$\net8.0\SpecFlow.Actions.Configuration.SpecFlowPlugin.*" target="lib\net8.0"/>

    <file src="bin\$config$\net48\SpecFlow.Actions.Configuration.Generation.SpecFlowPlugin.*" target="build\net48"/>
    <file src="bin\$config$\net8.0\SpecFlow.Actions.Configuration.Generation.SpecFlowPlugin.*" target="build\net8.0"/>

    <file src="bin\$config$\net48\SpecFlow.Actions.Configuration.SpecFlowPlugin.*" target="build\net48"/>
    <file src="bin\$config$\net8.0\SpecFlow.Actions.Configuration.SpecFlowPlugin.*" target="build\net8.0"/>

    <file src="$SolutionDir$LICENSE" target="LICENSE" />
    <file src="..\README.md" target="" />
  </files>
</package>
